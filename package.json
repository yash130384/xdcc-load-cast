{
  "name": "pulse-cast",
  "version": "1.0.0",
  "description": "PulseCast - Local web-based XDCC search, transfer, and cast client",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev:backend": "node server.js",
    "dev:frontend": "npm run dev --prefix client",
    "build:frontend": "npm run build --prefix client",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "airplayer": "^2.0.0",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "chromecast-api": "^0.4.2",
    "dlnacasts2": "^0.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "music-metadata": "^11.13.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
